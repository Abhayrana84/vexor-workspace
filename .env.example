# .env.example — copy to .env.local and fill in values

# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/vexor_workspace"

# ─── NextAuth ───────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"

# Your app URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL="http://localhost:3000"

# ─── Optional: Supabase (if using Supabase for PostgreSQL) ──────────────────
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"

# ─── Optional: Railway ──────────────────────────────────────────────────────
# DATABASE_URL is auto-injected by Railway when you link your DB service
